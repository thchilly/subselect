# Data — input-only; managed out-of-band, never tracked.
Data/

# Derived caches and legacy paper outputs — siblings of Data/, also out-of-band.
# `cache/` is built by the M6 cache layer; `results/` holds the legacy paper
# artefacts (results/greece/ etc.) that M3 fixtures are copied from.
cache/
results/

# Legacy code and notebooks — frozen, kept on disk for reference; not part
# of the public package surface.
legacy/

# Auto-generated Jupyter copies of Markdown files (created when an .md is
# opened in a Jupyter-aware viewer). The .md is the source of truth.
README.ipynb

# Cache & build artefacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# Test / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Notebook checkpoints
.ipynb_checkpoints/

# Virtual envs (the project uses a conda env named `subselect`; venvs would be local accidents)
.venv/
venv/
env/

# macOS / filesystem cruft
.DS_Store
._*
Icon?
.Spotlight-V100
.Trashes

# LaTeX build artefacts (methods.tex). The compiled methods.pdf is tracked
# alongside the .tex source; everything else is regenerated by pdflatex.
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz

# Review-figure outputs — derived from scripts/, not source.
notebooks/exploratory/m5_cropping_review/

# Internal project documentation and orchestration files (not for public repo).
docs/
CLAUDE.md
.claude/

# Project literature (kept locally for reference; not part of the public package).
papers/

# Historical paper-era reference outputs (xlsx snapshots), kept locally for
# audit but not part of the public methodology surface.
documentation/historical_paper_outputs/

# Development forensics under scripts/ — kept on disk for reference, not
# part of the public surface.
scripts/archive/
scripts/m9_cell_map.md
scripts/composite_taylor_explore.py
